ional arguments.","code":""},{"path":"https://r-xla.github.io/tengen/reference/shape.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"Shape — shape","text":"(integer()) shape tensor.","code":""},{"path":[]},{"path":"https://r-xla.github.io/tengen/news/index.html","id":"tengen-020","dir":"Changelog","previous_headings":"","what":"tengen 0.2.0","title":"tengen 0.2.0","text":"Added DataType class hierarchy: BooleanType, IntegerType, UIntegerType, FloatType ==/!= comparison, print(), .character() methods. Added as_dtype() generic convert strings (e.g. \"i32\", \"f64\") DataType objects. Added is_dtype() assert_dtype() helpers type checking. Added nelts() generic get number elements tensor. Renamed TensorDataType DataType.","code":""},{"path":"https://r-xla.github.io/tengen/news/index.html","id":"tengen-010","dir":"Changelog","previous_headings":"","what":"tengen 0.1.0","title":"tengen 0.1.0","text":"Initial release r-universe","code":""}]
