,"code":""},{"path":"https://r-xla.github.io/tengen/reference/as_raw.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"As Ray — as_raw","text":"()","code":""},{"path":"https://r-xla.github.io/tengen/reference/assert_dtype.html","id":null,"dir":"Reference","previous_headings":"","what":"Assert DataType — assert_dtype","title":"Assert DataType — assert_dtype","text":"Assert object DataType.","code":""},{"path":"https://r-xla.github.io/tengen/reference/assert_dtype.html","id":"ref-usage","dir":"Reference","previous_headings":"","what":"Usage","title":"Assert DataType — assert_dtype","text":"","code":"assert_dtype(x, arg = rlang::caller_arg(x))"},{"path":"https://r-xla.github.io/tengen/reference/assert_dtype.html","id":"arguments","dir":"Reference","previous_headings":"","what":"Arguments","title":"Assert DataType — assert_dtype","text":"x () Object check. arg (character(1)) Argument name error messages.","code":""},{"path":"https://r-xla.github.io/tengen/reference/assert_dtype.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"Assert DataType — assert_dtype","text":"NULL (invisibly). Called side effects.","code":""},{"path":"https://r-xla.github.io/tengen/reference/device.html","id":null,"dir":"Reference","previous_headings":"","what":"Device — device","title":"Device — device","text":"Get device tensor.","code":""},{"path":"https://r-xla.github.io/tengen/reference/device.html","id":"ref-usage","dir":"Reference","previous_headings":"","what":"Usage","title":"Device — device","text":"","code":"device(x, ...)"},{"path":"https://r-xla.github.io/tengen/reference/device.html","id":"arguments","dir":"Reference","previous_headings":"","what":"Arguments","title":"Device — device","text":"x () Object. ... () Additional arguments.","code":""},{"path":"https://r-xla.github.io/tengen/reference/device.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"Device — device","text":"()","code":""},{"path":"https://r-xla.github.io/tengen/reference/dtype.html","id":null,"dir":"Reference","previous_headings":"","what":"Data Type — dtype","title":"Data Type — dtype","text":"Get data type tensor. return type depends specific tensor implementation.","code":""},{"path":"https://r-xla.github.io/tengen/reference/dtype.html","id":"ref-usage","dir":"Reference","previous_headings":"","what":"Usage","title":"Data Type — dtype","text":"","code":"dtype(x, ...)"},{"path":"https://r-xla.github.io/tengen/reference/dtype.html","id":"arguments","dir":"Reference","previous_headings":"","what":"Arguments","title":"Data Type — dtype","text":"x () Object. ... () Additional arguments.","code":""},{"path":"https://r-xla.github.io/tengen/reference/dtype.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"Data Type — dtype","text":"()","code":""},{"path":"https://r-xla.github.io/tengen/reference/is_dtype.html","id":null,"dir":"Reference","previous_headings":"","what":"Is DataType — is_dtype","title":"Is DataType — is_dtype","text":"Check object DataType.","code":""},{"path":"https://r-xla.github.io/tengen/reference/is_dtype.html","id":"ref-usage","dir":"Reference","previous_headings":"","what":"Usage","title":"Is DataType — is_dtype","text":"","code":"is_dtype(x)"},{"path":"https://r-xla.github.io/tengen/reference/is_dtype.html","id":"arguments","dir":"Reference","previous_headings":"","what":"Arguments","title":"Is DataType — is_dtype","text":"x () Object check.","code":""},{"path":"https://r-xla.github.io/tengen/reference/is_dtype.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"Is DataType — is_dtype","text":"logical(1)","code":""},{"path":"https://r-xla.github.io/tengen/reference/ndims.html","id":null,"dir":"Reference","previous_headings":"","what":"Number of Dimensions — ndims","title":"Number of Dimensions — ndims","text":"Get number dimensions tensor.","code":""},{"path":"https://r-xla.github.io/tengen/ref